# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# In CI/CD, inject these as pipeline secrets instead of using a .env file.

# ── Environment ───────────────────────────────────────────────────────────────
# Target environment: dev | prod  (controls which configs/*.yaml is loaded)
ENV=dev

# ── Main App User ─────────────────────────────────────────────────────────────
# Used by: authenticated_page, test_login, test_super_admin, test_get_token
# Renamed from USERNAME to avoid conflict with the OS-level USERNAME variable
APP_USERNAME=testuser
APP_PASSWORD=Test@123

# ── Second App User ───────────────────────────────────────────────────────────
# Used by: credentials2 fixture (reserved for future multi-user tests)
# Renamed from SECOND_USER / SECOND_PASSWORD for consistency
APP2_USERNAME=pravin
APP2_PASSWORD=Q>*4h3yO

# ── Signa User ────────────────────────────────────────────────────────────────
# Used by: signa_page fixture, test_signa_user tests
SIGNA_USERNAME=signauser
SIGNA_PASSWORD=W9@g@JtC

# ── Super Admin User ──────────────────────────────────────────────────────────
# Used by: super_admin_credentials fixture, test_signa_user RBAC test
# SUPERADMIN_PASSWORD was missing from original .env — add it here
SUPERADMIN_USERNAME=testuser
SUPERADMIN_PASSWORD=

# ── Misc ──────────────────────────────────────────────────────────────────────
# Used by: test_forgot_password — must be a real registered account email
REGISTERED_EMAIL=srvnasigna@gmail.com
